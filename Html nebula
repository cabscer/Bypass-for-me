  <style>
    /* Nebulo V5.3 Theme */
    :root {
      --bg0: #070b14;
      --bg1: #0b1220;
      --card: rgba(16, 24, 40, 0.85);
      --card2: rgba(18, 28, 48, 0.92);
      --stroke: rgba(255, 255, 255, 0.12);
      --stroke2: rgba(125, 211, 192, 0.28);
      --text: #eaf0ff;
      --text-muted: rgba(234, 240, 255, 0.75);
      --text-secondary: rgba(234, 240, 255, 0.55);
      --accent: #7dd3c0;
      --accent2: #60a5fa;
      --danger: #ff5c7a;
      --success: #10b981;
      --warning: #f59e0b;
      --radius: 18px;
      --radius-sm: 14px;
      --radius-lg: 24px;
      --shadow: 0 20px 60px rgba(0, 0, 0, 0.65);
      --shadow-sm: 0 12px 32px rgba(0, 0, 0, 0.45);
      --shadow-lg: 0 30px 90px rgba(0, 0, 0, 0.75);
      --transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
      --transition-slow: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
    html, body {
      height: 100%;
      overflow-x: hidden;
      color: var(--text);
      background: 
        radial-gradient(1200px 700px at 50% 0%, rgba(96,165,250,.18), transparent 60%),
        radial-gradient(900px 600px at 12% 16%, rgba(125,211,192,.12), transparent 60%),
        radial-gradient(900px 600px at 85% 20%, rgba(139,92,246,.10), transparent 60%),
        linear-gradient(180deg, var(--bg0), var(--bg1));
    }
    body {
      min-height: 100vh;
      overflow-y: auto;
      padding: 0;
    }
    /* Background Particles */
    #particles-js {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: -1;
    }
    /* Main Content */
    .main-content {
      width: 100%;
      max-width: 800px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 40px;
      z-index: 1;
      padding: 40px 20px;
      min-height: 100vh;
    }
    /* Search Section */
    .search-section {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 24px;
      animation: fadeInUp 0.6s ease-out;
      margin-top: 20px;
    }
    .search-title-row {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .search-logo {
      width: 52px;
      height: 52px;
      border-radius: 16px;
      object-fit: contain;
      border: 1px solid rgba(255, 255, 255, 0.2);
      background: rgba(255, 255, 255, 0.05);
      padding: 6px;
    }
    .search-title {
      font-size: clamp(2.5rem, 8vw, 4rem);
      font-weight: 900;
      background: linear-gradient(90deg, 
        var(--accent) 0%, 
        var(--accent2) 50%, 
        var(--accent) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      text-align: center;
      letter-spacing: -0.02em;
      filter: drop-shadow(0 4px 20px rgba(125, 211, 192, 0.3));
      position: relative;
    }
    .search-title::after {
      content: '';
      position: absolute;
      bottom: -10px;
      left: 50%;
      transform: translateX(-50%);
      width: 100px;
      height: 4px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
      border-radius: 2px;
    }
    .search-container {
      width: 100%;
      max-width: 680px;
      position: relative;
    }
    .search-form {
      width: 100%;
      position: relative;
    }
    .search-input {
      width: 100%;
      padding: 20px 24px;
      font-size: 16px;
      font-weight: 500;
      color: var(--text);
      background: var(--card);
      border: 1px solid var(--stroke);
      border-radius: var(--radius-lg);
      backdrop-filter: blur(20px) saturate(180%);
      outline: none;
      transition: var(--transition);
      box-shadow: var(--shadow);
    }
    .search-input:focus {
      border-color: var(--accent);
      background: var(--card2);
      box-shadow: 
        var(--shadow),
        0 0 0 3px rgba(125, 211, 192, 0.15);
      transform: translateY(-2px);
    }
    .search-input::placeholder {
      color: var(--text-secondary);
    }
    .search-submit {
      position: absolute;
      right: 8px;
      top: 50%;
      transform: translateY(-50%);
      width: 48px;
      height: 48px;
      border-radius: var(--radius-sm);
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      border: none;
      color: white;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: var(--transition);
      box-shadow: 0 4px 20px rgba(125, 211, 192, 0.3);
    }
    .search-submit:hover {
      transform: translateY(-50%) scale(1.05);
      box-shadow: 0 6px 24px rgba(125, 211, 192, 0.4);
    }
    .search-submit i {
      font-size: 18px;
    }
    /* Quick Access */
    .quick-access {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 24px;
      animation: fadeInUp 0.6s ease-out 0.2s both;
    }
    .section-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text-muted);
      text-align: center;
      letter-spacing: 0.02em;
    }
    .quick-access-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
      gap: 16px;
      width: 100%;
    }
    .quick-access-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      padding: 20px 12px;
      background: var(--card);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      text-decoration: none;
      color: var(--text);
      transition: var(--transition);
      position: relative;
      overflow: hidden;
      backdrop-filter: blur(20px);
    }
    .quick-access-item:hover {
      transform: translateY(-4px);
      border-color: var(--accent);
      background: var(--card2);
      box-shadow: var(--shadow);
    }
    .quick-access-item::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      transform: scaleX(0);
      transition: transform 0.3s ease;
    }
    .quick-access-item:hover::before {
      transform: scaleX(1);
    }
    .quick-access-icon {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--stroke);
      overflow: hidden;
      transition: var(--transition);
      position: relative;
    }
    .quick-access-icon.fallback::after {
      content: attr(data-initial);
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 18px;
      color: #fff;
      background: rgba(0, 0, 0, 0.45);
      border-radius: 16px;
      z-index: 2;
    }
    .quick-access-item:hover .quick-access-icon {
      transform: scale(1.1);
      background: rgba(255, 255, 255, 0.08);
      border-color: var(--accent);
    }
    .quick-access-icon img {
      width: 32px;
      height: 32px;
      object-fit: contain;
      filter: brightness(1.1);
      z-index: 2;
      position: relative;
    }
    /* Color overlays for each service */
    .quick-access-icon::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 16px;
      opacity: 0.1;
      z-index: 1;
    }
    .quick-access-item[data-service="google"] .quick-access-icon::before {
      background: #4285F4;
    }
    .quick-access-item[data-service="youtube"] .quick-access-icon::before {
      background: #FF0000;
    }
    .quick-access-item[data-service="reddit"] .quick-access-icon::before {
      background: #FF4500;
    }
    .quick-access-item[data-service="discord"] .quick-access-icon::before {
      background: #5865F2;
    }
    .quick-access-item[data-service="github"] .quick-access-icon::before {
      background: #333333;
    }
    .quick-access-item[data-service="spotify"] .quick-access-icon::before {
      background: #1DB954;
    }
    .quick-access-item[data-service="twitter"] .quick-access-icon::before {
      background: #1DA1F2;
    }
    .quick-access-item[data-service="netflix"] .quick-access-icon::before {
      background: #E50914;
    }
    .quick-access-item[data-service="chat"] .quick-access-icon::before {
      background: rgba(125, 211, 192, 0.4);
    }
    .quick-access-label {
      font-size: 14px;
      font-weight: 600;
      color: var(--text-muted);
      text-align: center;
      transition: var(--transition);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 100%;
      padding: 0 4px;
    }
    .quick-access-item:hover .quick-access-label {
      color: var(--text);
    }
    /* Search Suggestions */
    .suggestions-container {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      right: 0;
      background: var(--card2);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      backdrop-filter: blur(20px) saturate(180%);
      box-shadow: var(--shadow);
      overflow: hidden;
      z-index: 1000;
      display: none;
      max-height: 400px;
      overflow-y: auto;
    }
    .suggestion-item {
      padding: 14px 20px;
      display: flex;
      align-items: center;
      gap: 14px;
      cursor: pointer;
      transition: var(--transition);
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .suggestion-item:hover {
      background: rgba(255, 255, 255, 0.05);
    }
    .suggestion-item:last-child {
      border-bottom: none;
    }
    .suggestion-icon {
      width: 24px;
      height: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--accent);
      flex-shrink: 0;
    }
    .suggestion-text {
      flex: 1;
      font-size: 14px;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .suggestion-url {
      font-size: 12px;
      color: var(--text-secondary);
      margin-top: 2px;
    }
    /* Recent Searches */
    .recent-searches {
      width: 100%;
      max-width: 680px;
      margin-top: 20px;
      animation: fadeInUp 0.6s ease-out 0.4s both;
    }
    .recent-searches-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-secondary);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .recent-searches-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .recent-search-tag {
      padding: 8px 16px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--stroke);
      border-radius: 20px;
      color: var(--text-muted);
      font-size: 14px;
      cursor: pointer;
      transition: var(--transition);
    }
    .recent-search-tag:hover {
      background: rgba(125, 211, 192, 0.1);
      border-color: var(--accent);
      color: var(--text);
      transform: translateY(-2px);
    }
    /* Bottom Info */
    .bottom-info {
      margin-top: 60px;
      text-align: center;
      color: var(--text-secondary);
      font-size: 12px;
      animation: fadeInUp 0.6s ease-out 0.6s both;
      padding: 20px;
      border-top: 1px solid var(--stroke);
      width: 100%;
      max-width: 680px;
    }
    .proxy-status {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      background: rgba(125, 211, 192, 0.1);
      border: 1px solid rgba(125, 211, 192, 0.2);
      border-radius: 20px;
      margin-bottom: 12px;
    }
    .proxy-status i {
      color: var(--accent);
    }
    /* Scroll to top button */
    .scroll-to-top {
      position: fixed;
      bottom: 30px;
      right: 30px;
      width: 50px;
      height: 50px;
      background: var(--card);
      border: 1px solid var(--stroke);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text);
      cursor: pointer;
      transition: var(--transition);
      z-index: 1000;
      opacity: 0;
      visibility: hidden;
      backdrop-filter: blur(20px);
    }
    .scroll-to-top.visible {
      opacity: 1;
      visibility: visible;
    }
    .scroll-to-top:hover {
      background: var(--card2);
      border-color: var(--accent);
      transform: translateY(-3px);
    }
    /* Animations */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    /* Responsive */
    @media (max-width: 768px) {
      .main-content {
        padding: 30px 16px;
        gap: 32px;
      }
      .search-input {
        padding: 16px 20px;
        font-size: 15px;
      }
      .quick-access-grid {
        grid-template-columns: repeat(auto-fit, minmax(90px, 1fr));
        gap: 12px;
      }
      .quick-access-item {
        padding: 16px 8px;
      }
      .quick-access-icon {
        width: 48px;
        height: 48px;
      }
      .quick-access-icon img {
        width: 24px;
        height: 24px;
      }
      .quick-access-label {
        font-size: 13px;
      }
      .scroll-to-top {
        bottom: 20px;
        right: 20px;
        width: 44px;
        height: 44px;
      }
    }
    @media (max-width: 480px) {
      .main-content {
        padding: 20px 12px;
      }
      .search-section {
        margin-top: 10px;
      }
      .quick-access-grid {
        grid-template-columns: repeat(3, 1fr);
      }
      .search-input {
        padding: 14px 18px;
      }
      .search-submit {
        width: 44px;
        height: 44px;
      }
      .quick-access-item {
        padding: 12px 6px;
        gap: 8px;
      }
      .quick-access-icon {
        width: 44px;
        height: 44px;
      }
      .quick-access-icon img {
        width: 20px;
        height: 20px;
      }
      .scroll-to-top {
        bottom: 15px;
        right: 15px;
        width: 40px;
        height: 40px;
      }
    }
    /* Custom Scrollbar */
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }
    ::-webkit-scrollbar-track {
      background: rgba(255, 255, 255, 0.05);
      border-radius: 10px;
    }
    ::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.1);
      border-radius: 10px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: rgba(255, 255, 255, 0.15);
    }
  </style>
